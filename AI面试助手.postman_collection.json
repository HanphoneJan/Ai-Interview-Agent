				{
					"name": "/api/accounts/login/",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// 处理登录响应，提取并存储Token\r",
									"let responseData = pm.response.json();\r",
									"\r",
									"// 检查响应是否成功\r",
									"if (pm.response.code === 200) {\r",
									"    // 从响应中提取Token（根据实际响应结构调整）\r",
									"    let token = responseData.token || responseData.access || responseData.data.token;\r",
									"    \r",
									"    if (token) {\r",
									"        // 存储Token到环境变量（也可存储到全局变量）\r",
									"        pm.environment.set(\"access\", token);\r",
									"        \r",
									"        // 记录Token和过期时间（JWT场景）\r",
									"        if (responseData.refresh) {\r",
									"            pm.environment.set(\"refresh\", responseData.refresh);\r",
									"        }\r",
									"        \r",
									"        // 计算Token过期时间（假设有效期24小时）\r",
									"        let expiresAt = new Date().getTime() + (24 * 60 * 60 * 1000);\r",
									"        pm.environment.set(\"token_expires_at\", expiresAt);\r",
									"        \r",
									"        pm.test(\"Token获取成功\", () => {\r",
									"            pm.expect(token).to.not.be.empty;\r",
									"        });\r",
									"        \r",
									"    } else {\r",
									"        pm.test(\"响应中包含Token\", () => {\r",
									"            pm.expect(token).to.not.be.undefined;\r",
									"        });\r",
									"    }\r",
									"} else {\r",
									"    pm.test(\"登录请求成功\", () => {\r",
									"        pm.response.to.have.status(200);\r",
									"    });\r",
									"    \r",
									"    // 错误处理\r",
									"    let errorMsg = responseData.error || \"登录失败，请检查用户名和密码\";\r",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						},
