				{
					"name": "/api/accounts/delete-user/",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// 自动添加Token到请求头\r",
									"let authToken = pm.environment.get(\"access\");\r",
									"let tokenExpiresAt = pm.environment.get(\"token_expires_at\");\r",
									"let now = new Date().getTime();\r",
									"\r",
									"// 检查Token是否存在且未过期\r",
									"if (authToken && tokenExpiresAt && now < tokenExpiresAt) {\r",
									"    // 添加Token到请求头（根据认证方式调整）\r",
									"    pm.request.headers.upsert({\r",
									"        key: \"Authorization\",\r",
									"        //value: \"Token \" + authToken  // 适用于Token认证\r",
									"        value: \"Bearer \" + authToken  // 适用于JWT认证\r",
									"    });\r",
									"    \r",
									"} else {\r",
									"  \r",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
