<!-- pages/interview/position/position.wxml -->
<view class="position-container">
  <!-- 页面头部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="iconfont icon-back"></text>
    </view>
    <view class="title">选择面试岗位</view>
    <view class="placeholder"></view>
  </view>

  <!-- 搜索框 -->
  <view class="search-box">
    <view class="search-input-wrap">
      <text class="iconfont icon-search"></text>
      <input 
        class="search-input" 
        placeholder="搜索岗位" 
        value="{{searchValue}}"
        bindinput="onSearch"
        confirm-type="search"
      />
      <text class="iconfont icon-clear" bindtap="clearSearch" wx:if="{{searchValue}}"></text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 岗位列表 -->
  <scroll-view 
    class="position-list" 
    scroll-y="true" 
    enable-flex="true"
    wx:if="{{!loading}}"
  >
    <block wx:for="{{filteredPositions}}" wx:key="id">
      <view 
        class="position-item {{selectedId === item.id ? 'selected' : ''}}" 
        bindtap="selectPosition"
        data-id="{{item.id}}"
      >
        <view class="position-header">
          <image class="position-icon" src="{{item.icon}}" mode="aspectFit"></image>
          <view class="position-title">{{item.name}}</view>
          <view class="position-check" wx:if="{{selectedId === item.id}}">
            <text class="iconfont icon-check"></text>
          </view>
        </view>
        
        <view class="position-description">{{item.description}}</view>
        
        <view class="position-tags">
          <block wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">
            <view class="tag">{{tag}}</view>
          </block>
        </view>
        
        <view class="position-footer">
          <view class="position-info">
            <text class="info-item">
              <text class="iconfont icon-question"></text>
              <text>{{item.questionCount}}个问题</text>
            </text>
            <text class="info-item">
              <text class="iconfont icon-time"></text>
              <text>约{{item.duration}}分钟</text>
            </text>
          </view>
        </view>
      </view>
    </block>

    <!-- 无搜索结果 -->
    <view class="no-result" wx:if="{{searchValue && filteredPositionsCount === 0}}">
      <image class="no-result-image" src="/assets/images/no_result.png" mode="aspectFit"></image>
      <text class="no-result-text">没有找到相关岗位</text>
    </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-button-container">
    <button 
      class="start-button {{selectedId ? 'active' : 'disabled'}}" 
      bindtap="startInterview"
    >
      开始面试
    </button>
  </view>
</view>