/* pages/user/profile/profile.wxss */

.profile-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 30rpx;
}

.header {
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eaeaea;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
}

/* 用户信息区域 */
.user-info-section {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background-color: #ffffff;
  margin: 30rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid #f0f0f0;
  margin-right: 30rpx;
}

.info-container {
  flex: 1;
}

.name-container {
  margin-bottom: 10rpx;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.nickname {
  font-size: 28rpx;
  color: #999999;
}

/* 登录按钮 */
.login-btn-container {
  padding: 0 30rpx;
  margin-top: 20rpx;
}

.login-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 30rpx;
  border-radius: 40rpx;
}

.login-btn::after {
  border: none;
}

/* 功能区 */
.function-section {
  background-color: #ffffff;
  margin: 30rpx;
  border-radius: 12rpx;
  padding: 20rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.function-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.function-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.function-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
}

.item-text {
  font-size: 30rpx;
  color: #333333;
  margin-left: 20rpx;
}

.item-right {
  display: flex;
  align-items: center;
}

.status-text {
  font-size: 28rpx;
  color: #999999;
  margin-right: 10rpx;
}

/* 图标样式 */
.iconfont {
  font-size: 36rpx;
  color: #666666;
}

.icon-file, .icon-history {
  color: #07c160;
}

.icon-right {
  font-size: 28rpx;
  color: #cccccc;
}


/* 新增样式 */
.avatar-btn {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
}
.avatar-btn::after {
  border: none;
}

.default-info {
  display: flex;
  flex-direction: column;
}

.nickname-input {
  border-bottom: 1px solid #07c160;
  padding: 10rpx;
  font-size: 32rpx;
  width: 200rpx;
}