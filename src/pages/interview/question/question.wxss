/* pages/interview/question/question.wxss */

.question-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  display: flex;
  flex-direction: column;
}

/* 页面头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  position: relative;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.timer {
  display: flex;
  align-items: center;
  color: #07c160;
}

.timer-text {
  font-size: 28rpx;
  margin-left: 8rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

/* 面试准备页面 */
.interview-ready {
  padding: 30rpx;
}

.position-info {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.position-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.position-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.position-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

.interview-info {
  display: flex;
  justify-content: space-around;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666666;
}

.info-item text {
  margin-left: 8rpx;
}

/* 提示区域 */
.tips-container {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.tips-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.tips-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.tips-toggle {
  font-size: 28rpx;
  color: #07c160;
}

.tips-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.tip-item {
  margin-bottom: 10rpx;
}

.tips-collapsed {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  color: #07c160;
  font-size: 28rpx;
}

/* 倒计时页面 */
.countdown-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #07c160;
}

.countdown-number {
  font-size: 120rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 30rpx;
}

.countdown-text {
  font-size: 32rpx;
  color: #ffffff;
}

/* 面试进行中页面 */
.interview-ongoing {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.question-progress {
  padding: 20rpx 30rpx;
  background-color: #ffffff;
}

.progress-bar {
  height: 6rpx;
  background-color: #f0f0f0;
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-inner {
  height: 100%;
  background-color: #07c160;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999999;
  text-align: right;
}

.question-content {
  padding: 30rpx;
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.question-type {
  margin-bottom: 20rpx;
}

.type-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.type-tag.basic {
  background-color: rgba(7, 193, 96, 0.1);
  color: #07c160;
}

.type-tag.technical {
  background-color: rgba(64, 158, 255, 0.1);
  color: #409eff;
}

.type-tag.behavioral {
  background-color: rgba(255, 153, 0, 0.1);
  color: #ff9900;
}

.question-text {
  font-size: 32rpx;
  color: #333333;
  line-height: 1.6;
}

/* 摄像头区域 */
.camera-container {
  position: relative;
  width: 100%;
  height: 400rpx;
  background-color: #000000;
  margin-bottom: 20rpx;
}

.camera {
  width: 100%;
  height: 100%;
}

.camera-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ffffff;
}

.pause-text {
  font-size: 32rpx;
  margin-top: 20rpx;
}

.camera-controls {
  position: absolute;
  bottom: 30rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
}

/* 语音识别区域 */
.recognition-container {
  flex: 1;
  background-color: #ffffff;
  padding: 20rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.recognition-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.recognition-title {
  font-size: 28rpx;
  color: #333333;
}

.recognition-status {
  font-size: 24rpx;
  color: #999999;
}

.recognition-status.active {
  color: #07c160;
}

.recognition-content {
  height: 200rpx;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* 按钮样式 */
.start-button, .next-button {
  width: 100% !important;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 44rpx;
  margin-top: 30rpx;
}

.start-button::after, .next-button::after {
  border: none;
}

/* 面试完成页面 */
.interview-completed {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #ffffff;
}

.completed-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.completed-icon .iconfont {
  font-size: 60rpx;
  color: #ffffff;
}

.completed-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.completed-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 40rpx;
}

.completed-stats {
  display: flex;
  gap: 60rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

/* 图标样式 */
.iconfont {
  font-size: 36rpx;
  color: #666666;
}

.icon-back {
  font-size: 32rpx;
}

.icon-time {
  font-size: 28rpx;
  color: #07c160;
}

.icon-tips {
  font-size: 32rpx;
  color: #07c160;
  margin-right: 8rpx;
}

.icon-pause, .icon-play, .icon-next {
  font-size: 40rpx;
  color: #ffffff;
}

.icon-success {
  color: #ffffff;
}